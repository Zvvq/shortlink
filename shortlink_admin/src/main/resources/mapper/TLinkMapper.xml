<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace=".mapper.TLinkMapper">

    <resultMap id="BaseResultMap" type=".TLink">
            <id property="id" column="id" />
            <result property="domain" column="domain" />
            <result property="shortUri" column="short_uri" />
            <result property="fullShortUrl" column="full_short_url" />
            <result property="originUrl" column="origin_url" />
            <result property="clickNum" column="click_num" />
            <result property="gid" column="gid" />
            <result property="enableStatus" column="enable_status" />
            <result property="createdType" column="created_type" />
            <result property="validDateType" column="valid_date_type" />
            <result property="validDate" column="valid_date" />
            <result property="describe" column="describe" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="Base_Column_List">
        id,domain,short_uri,full_short_url,origin_url,click_num,
        gid,enable_status,created_type,valid_date_type,valid_date,
        describe,create_time,update_time,del_flag
    </sql>
</mapper>
